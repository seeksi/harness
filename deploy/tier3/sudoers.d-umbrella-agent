# Tier-3 / G1 — sudoers fragment: deploy may run ONLY the agent-exec wrapper as `agent`.
#
# Install to: /etc/systemd/.. NO — install to /etc/sudoers.d/umbrella-agent
#   owner root:root, mode 0440 (sudo refuses group/world-writable drop-ins).
#   $ sudo install -m 0440 -o root -g root \
#         deploy/tier3/sudoers.d-umbrella-agent /etc/sudoers.d/umbrella-agent
#
# VALIDATE BEFORE TRUSTING (a broken sudoers can lock you out):
#   $ sudo visudo -cf /etc/sudoers.d/umbrella-agent     # must print: parsed OK
#   (visudo -c checks the whole /etc/sudoers tree incl. this drop-in.)
#
# Contract from the sandbox buildInvocation (laneUser(i)):
#   sudo -n -H -u agent[-i] -- /opt/umbrella/deploy/agent-exec-wrapper.sh <args...>
#   -n  never prompt (fail closed)      -H  HOME from the lane user's passwd (its ~/.claude)
# The Cmnd is the wrapper's ABSOLUTE path with NO args, so deploy may pass ANY args to
# THIS ONE binary as a POOL user — but cannot run anything else as them, and cannot swap the
# binary (agent-bridge pins AGENT_CLI_PATH; this rule pins the path sudo will accept).
#
# POOL (#17 17b): concurrent lanes run as DISTINCT uids — lane 0 = agent, lane i>0 = agent-i.
# The Runas list below enumerates the pool (default MAX_LANES=5 → agent + agent-1..agent-4).
# It is a CLOSED list (no wildcard): deploy may become ONLY these named users, nothing else.
# If MAX_LANES is raised in 01b-provision-lane-users.sh, extend this list to match and re-run
# `visudo -cf` (an agent-N with no Runas entry here would fail closed at the sudo call).

# env_reset (sudo default) drops deploy's environment so no daemon env/secret reaches the
# agent. secure_path is restricted to trusted system dirs for the agent command context.
Defaults!UMBRELLA_AGENT_EXEC env_reset
Defaults!UMBRELLA_AGENT_EXEC secure_path="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
# Command-scoped env_keep (NOT a broad SETENV) so the sandbox's optional resourceLimits
# survive env_reset and reach the wrapper. Bounded, validated NUMERIC values ONLY
# (lib/sandbox validateLimits enforces ^\d+[KMGT]?$ / ^\d+% / positive-int-with-cap) —
# never secrets. ponytail: the wrapper (provisioner chunk) reads these + clamps-to-default.
Defaults!UMBRELLA_AGENT_EXEC env_keep += "SANDBOX_MEM_MAX SANDBOX_TASKS_MAX SANDBOX_CPU_QUOTA SANDBOX_CPU_SECONDS"

# The single allowed command alias — exact absolute path, no wildcards.
Cmnd_Alias UMBRELLA_AGENT_EXEC = /opt/umbrella/deploy/agent-exec-wrapper.sh

# deploy may run that wrapper as ANY pool user only, password-less. NOTHING else is granted.
# Closed Runas list (MAX_LANES=5): agent + agent-1..agent-4. Extend if MAX_LANES grows.
deploy ALL=(agent,agent-1,agent-2,agent-3,agent-4) NOPASSWD: UMBRELLA_AGENT_EXEC

# ponytail: the rule trusts the wrapper file's integrity. Ceiling: if the wrapper were
# agent-writable the agent could rewrite its own limits. Upgrade path: keep the wrapper
# root-owned 0755 (provision step does this) and/or add a dpkg/aide integrity check.
#
# skipped: per-arg command restriction (e.g. forcing --allowedTools), add if you want
# sudoers (not just the daemon) to enforce the tool allowlist — args are free-form here.
